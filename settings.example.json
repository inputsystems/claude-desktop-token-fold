{
  "env": {
    "FOLD_BASH_OUTPUT": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/fold-bash-output.py\""
          }
        ]
      }
    ]
  }
}
